# =============================================================================
# TIER 1 PIPELINE ENFORCEMENT — npm config
# Replaces: security/enforce-dependency-pinning
# =============================================================================

# Pin all installs to exact versions — no silent patch/minor updates
save-exact=true

# Fail install if Node version doesn't match `engines` field in package.json
engine-strict=true

# Fail install if any moderate or higher vulnerability is found
audit-level=moderate

# Suppress funding messages in CI output
fund=false
